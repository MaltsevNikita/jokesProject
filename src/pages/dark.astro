---
import Layout from "../layouts/Layout.astro";
import '../styles/global.css'

const fetchJoke = async () => {
  const response = await fetch("https://abhi-api.vercel.app/api/fun/jdark");
  const data = await response.json();
  return {
    setup: data.result.setup,
    punchline: data.result.punchline
  };
};

const jokes = await Promise.all([
  fetchJoke(),
  fetchJoke(),
  fetchJoke(),
  fetchJoke(),
  fetchJoke()
]);

---

<Layout>
    <div class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-zinc-900 py-12 px-4">
        <h1 class="text-4xl font-black text-center text-red-500 mb-10">😈 Dark Jokes</h1>
        <div class="max-w-2xl mx-auto space-y-6">
            {jokes.map((joke) => (
                <div class="bg-slate-800/80 backdrop-blur-sm rounded-2xl p-6 shadow-lg border border-slate-700 hover:shadow-red-900/20 hover:scale-[1.02] transition-all duration-300 cursor-default">
                    <p class="text-lg font-medium text-slate-200 leading-relaxed mb-3">{joke.setup}</p>
                    <p class="text-red-400 font-bold text-lg">{joke.punchline}</p>
                </div>
            ))}
        </div>
    </div>
</Layout>