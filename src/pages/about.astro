---
import Layout from "../layouts/Layout.astro"
import '../styles/global.css'
---

<Layout title="About">
	<div class="about-page">
		<div class="container">
			<h1 class="title">About</h1>
			<div class="content">
				<div class="author-card">
					<div class="avatar">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
					</div>
					<h2>Author</h2>
					<p class="name">Никита</p>
					<a href="https://t.me/maltsevNik" class="telegram" target="_blank" rel="noopener">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.065-1.226-.461-1.901-.903-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.139-5.062 3.345-.479.329-.913.49-1.302.48-.428-.008-1.252-.242-1.865-.44-.751-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
						@maltsevNik
					</a>
					<a href="https://www.malnik.ru" class="website" target="_blank" rel="noopener">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
						www.malnik.ru
					</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.about-page {
		min-height: calc(100vh - 80px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem 1rem;
		background: 
			radial-gradient(ellipse at 20% 80%, rgba(248, 113, 113, 0.1) 0%, transparent 50%),
			radial-gradient(ellipse at 80% 20%, rgba(251, 191, 36, 0.08) 0%, transparent 50%);
	}

	.container {
		max-width: 600px;
		width: 100%;
		text-align: center;
	}

	.title {
		font-size: 2.5rem;
		font-weight: 800;
		color: #1f2937;
		margin-bottom: 2rem;
	}

	.author-card {
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.8);
		border-radius: 1.5rem;
		padding: 2.5rem;
		transition: all 0.3s ease;
	}

	.author-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
	}

	.avatar {
		width: 80px;
		height: 80px;
		margin: 0 auto 1rem;
		background: linear-gradient(135deg, #ef4444, #dc2626);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.avatar svg {
		width: 40px;
		height: 40px;
		color: white;
	}

	.author-card h2 {
		font-size: 0.875rem;
		font-weight: 600;
		color: #6b7280;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.name {
		font-size: 1.5rem;
		font-weight: 700;
		color: #1f2937;
		margin-bottom: 1.5rem;
	}

	.telegram {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		background: linear-gradient(135deg, #229ED9, #0088cc);
		color: white;
		text-decoration: none;
		border-radius: 0.75rem;
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.telegram:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(34, 158, 217, 0.4);
	}

	.telegram svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.website {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		background: linear-gradient(135deg, #6366f1, #4f46e5);
		color: white;
		text-decoration: none;
		border-radius: 0.75rem;
		font-weight: 600;
		transition: all 0.3s ease;
		margin-top: 0.75rem;
	}

	.website:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
	}

	.website svg {
		width: 1.25rem;
		height: 1.25rem;
	}
</style>
