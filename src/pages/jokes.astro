---
import Layout from "../layouts/Layout.astro";
import '../styles/global.css'

const fetchJoke = async () => {
  const response = await fetch("https://abhi-api.vercel.app/api/fun/jdev");
  const data = await response.json();
  return {
    setup: data.result.setup,
    punchline: data.result.punchline
  };
};

const jokes = await Promise.all([
  fetchJoke(),
  fetchJoke(),
  fetchJoke(),
  fetchJoke(),
  fetchJoke()
]);

---

<Layout>
    <div class="min-h-screen bg-gradient-to-br from-amber-50 via-orange-50 to-yellow-50 py-12 px-4">
        <h1 class="text-4xl font-black text-center text-amber-600 mb-10">😂 Jokes</h1>
        <div class="max-w-2xl mx-auto space-y-6">
            {jokes.map((joke) => (
                <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 shadow-lg border border-amber-100 hover:shadow-xl hover:scale-[1.02] transition-all duration-300 cursor-default">
                    <p class="text-lg font-medium text-slate-800 leading-relaxed mb-3">{joke.setup}</p>
                    <p class="text-amber-600 font-bold text-lg">{joke.punchline}</p>
                </div>
            ))}
        </div>
    </div>
</Layout>